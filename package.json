{
  "name": "pbsabella.github.io",
  "version": "1.0.0",
  "description": "Personal Website",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "npm run build && npm run check:quality && npm run check:tests && npm run check:perf",
    "check:quality": "npm run type-check && npm run lint && npm run contrast:manual",
    "check:tests": "npm run test && npm run test:local && npm run pw:test",
    "check:perf": "npm run lighthouse",
    "lint": "eslint . && stylelint 'src/**/*.css' && node scripts/check-css-prefix.mjs && node scripts/check-breakpoints.mjs",
    "lint:eslint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:stylelint": "stylelint 'src/**/*.css' --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "cypress:open": "cypress open",
    "cypress:e2e": "cypress run --browser chrome --headless",
    "lighthouse": "LH_QUIET=1 start-server-and-test \"npm run preview -- --host 127.0.0.1 --port 4173\" http://localhost:4173 \"node scripts/lighthouse-routes.mjs\"",
    "lighthouse:quick": "LH_QUIET=1 LH_RUNS=1 start-server-and-test \"npm run preview -- --host 127.0.0.1 --port 4173\" http://localhost:4173 \"node scripts/lighthouse-routes.mjs\"",
    "pw:install": "playwright install chromium firefox webkit",
    "pw:test": "playwright test",
    "pw:smoke": "playwright test playwright/smoke",
    "pw:headed": "playwright test --headed",
    "contrast:manual": "start-server-and-test \"npm run dev -- --port 5173 --strictPort\" http://localhost:5173 \"node scripts/manual-contrast-audit.mjs\"",
    "test:local": "start-server-and-test dev http://localhost:5173 cypress:e2e",
    "percy:test": "start-server-and-test 'npm run preview -- --port 5173' http://localhost:5173 'percy exec -- cypress run'",
    "percy:baseline": "PERCY_BRANCH=master percy exec -- cypress run --config baseUrl=https://pbsabella.vercel.app/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pbsabella/pbsabella.github.io.git"
  },
  "keywords": [
    "html",
    "css",
    "responsive",
    "react"
  ],
  "author": "Paula Bianca Abella",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pbsabella/pbsabella.github.io/issues"
  },
  "homepage": "https://github.com/pbsabella/pbsabella.github.io#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@percy/cli": "^1.31.10",
    "@percy/cypress": "^3.1.7",
    "@playwright/test": "^1.58.2",
    "@testing-library/cypress": "^10.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "cypress": "^15.13.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.2.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "start-server-and-test": "^3.0.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "lucide-react": "^1.7.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,html}": [
      "prettier --write"
    ]
  }
}
